# =============================================================================
# Dockerfile.cli-worker — imagem PER-TOOL de um CLI worker da frota multi-CLI.
#
# Plano §1.8: runtimes divergem (node20 vs node22 vs pip vs binário) → NÃO cabe
# imagem única. Esta imagem é parametrizada por ``--build-arg WORKER_KIND=<kind>``
# e produz ``deile-cli-worker-<kind>:local``. A camada-base (Python + servidor
# genérico + git/gh/glab + _worker_core + cli_adapters) é compartilhada via cache;
# o stage final instala SÓ o CLI do kind escolhido (bloco condicional, espelha o
# padrão ``WITH_BOT`` do Dockerfile principal).
#
# INVARIANTE: esta imagem só é construída sob demanda (``deploy.py k8s
# build-cli-workers --kind <k>``); ``k8s up`` jamais a constrói nem a exige. Um
# CLI worker é 100%% opt-in.
#
# Build (a partir da RAIZ do repo, como o Dockerfile principal):
#   nerdctl --namespace k8s.io build -f infra/k8s/Dockerfile.cli-worker \
#       --build-arg WORKER_KIND=opencode -t deile-cli-worker-opencode:local .
# =============================================================================
ARG PYTHON_VERSION=3.11.10

# ---- builder: venv com aiohttp (o servidor genérico é aiohttp) --------------
FROM python:${PYTHON_VERSION}-slim AS builder
ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1
RUN python -m venv /venv \
    && /venv/bin/pip install --upgrade pip wheel \
    && /venv/bin/pip install "aiohttp>=3.9"

# ---- final: base comum + install per-kind -----------------------------------
FROM python:${PYTHON_VERSION}-slim AS final

ARG WORKER_KIND=opencode

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/venv/bin:/usr/local/bin:${PATH}" \
    DEILE_CLI_WORKER_KIND=${WORKER_KIND}

# tini (zombie reaper — o worker faz shell-out via git/CLI), git, curl, gh, glab.
# git/gh/glab são obrigatórios: o git_strategy de qualquer adapter precisa
# commitar+pushar (brief_driven) ou só pushar (cli_autocommit).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        tini git iputils-ping curl ca-certificates gnupg jq procps \
    && mkdir -p -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# glab (GitLab CLI) — version PINNED + SHA256 verificado (paridade com o
# Dockerfile principal). Forge-agnóstico: o worker pode pushar para GH ou GL.
ARG GLAB_VERSION=1.45.0
ARG GLAB_SHA256_AMD64=3efe5be6d5fd6c3346d2cabd2ca35d7f85a5ae5d97da8c90dff81557124dc519
ARG GLAB_SHA256_ARM64=2bd45d6d0f7c6af15604720dc8d177a3a15661230bcee45334879c5928de57bc
RUN ARCH="$(dpkg --print-architecture)" \
    && case "$ARCH" in \
        amd64) GLAB_ARCH=x86_64 ; EXPECTED_SHA="$GLAB_SHA256_AMD64" ;; \
        arm64) GLAB_ARCH=arm64  ; EXPECTED_SHA="$GLAB_SHA256_ARM64" ;; \
        *) echo "unsupported arch for glab: $ARCH" >&2; exit 1 ;; \
    esac \
    && curl -fsSL -o /tmp/glab.deb \
        "https://gitlab.com/gitlab-org/cli/-/releases/v${GLAB_VERSION}/downloads/glab_${GLAB_VERSION}_Linux_${GLAB_ARCH}.deb" \
    && echo "${EXPECTED_SHA}  /tmp/glab.deb" | sha256sum -c - \
    && dpkg -i /tmp/glab.deb \
    && rm /tmp/glab.deb \
    && gh --version \
    && glab --version

# venv com aiohttp.
COPY --from=builder /venv /venv

# -----------------------------------------------------------------------------
# Bloco de install PER-CLI — gated por WORKER_KIND. Cada bloco instala SÓ o
# runtime + binário daquele CLI. Versões PINADAS (nunca ``upgrade`` em runtime).
# Mantido em paridade com as specs da Parte 2 do plano (flags validadas via
# context7 contra a doc oficial de cada CLI).
# -----------------------------------------------------------------------------

# opencode — binário standalone (Tier 1). Pin de versão; ``upgrade`` proibido.
ARG OPENCODE_VERSION=0.4.45
RUN if [ "$WORKER_KIND" = "opencode" ]; then \
        curl -fsSL https://opencode.ai/install | VERSION="${OPENCODE_VERSION}" bash \
        && (opencode --version || /root/.opencode/bin/opencode --version || true) ; \
    fi

# aider — pip (Tier 1, cli_autocommit). Precisa de git (já instalado).
ARG AIDER_VERSION=0.86.1
RUN if [ "$WORKER_KIND" = "aider" ]; then \
        /venv/bin/pip install "aider-chat==${AIDER_VERSION}" \
        && aider --version ; \
    fi

# goose — binário (Tier 1). CONFIGURE=false evita o wizard interativo no
# install; GOOSE_DISABLE_KEYRING é setado em runtime (env_overlay do adapter).
ARG GOOSE_VERSION=1.0.30
RUN if [ "$WORKER_KIND" = "goose" ]; then \
        curl -fsSL https://github.com/block/goose/releases/download/v${GOOSE_VERSION}/download_cli.sh \
            | CONFIGURE=false bash \
        && (goose --version || /root/.local/bin/goose --version || true) ; \
    fi

# qwen — node>=22 + npm (Tier 2). Runtime node22 PRÓPRIO desta imagem (conflito
# com o node20 do claude-stack → o per-tool image resolve, plano §1.8).
ARG QWEN_VERSION=0.0.14
RUN if [ "$WORKER_KIND" = "qwen" ]; then \
        curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
        && apt-get install -y --no-install-recommends nodejs \
        && rm -rf /var/lib/apt/lists/* \
        && npm install -g --omit=dev "@qwen-code/qwen-code@${QWEN_VERSION}" \
        && qwen --version ; \
    fi

# codex — npm (Tier 2; OpenAI direto, ver caveat wire_api=responses no adapter).
ARG CODEX_VERSION=0.41.0
RUN if [ "$WORKER_KIND" = "codex" ]; then \
        curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
        && apt-get install -y --no-install-recommends nodejs \
        && rm -rf /var/lib/apt/lists/* \
        && npm install -g --omit=dev "@openai/codex@${CODEX_VERSION}" \
        && codex --version ; \
    fi

# Garante PATH dos binários instalados em $HOME por scripts de install.
ENV PATH="/usr/local/bin:/venv/bin:/home/${WORKER_KIND}/.opencode/bin:/home/${WORKER_KIND}/.local/bin:${PATH}"

# Non-root user nomeado pelo kind (HOME = /home/<kind>, casa com o manifest).
RUN groupadd --system --gid 10001 cliworker \
    && useradd  --system --uid 10001 --gid 10001 \
        --home-dir /home/${WORKER_KIND} --shell /usr/sbin/nologin cliworker \
    && mkdir -p /home/${WORKER_KIND} /app \
    && chown -R 10001:10001 /home/${WORKER_KIND} /app

# Servidor genérico + core agnóstico + registro de adapters. O servidor importa
# ``_worker_core``, ``cli_adapters`` (pacote), ``dispatch_logger`` e ``jsonl_cost``
# por nome — todos precisam ficar em /app lado a lado.
COPY --chown=10001:10001 infra/k8s/cli_worker_server.py /app/cli_worker_server.py
COPY --chown=10001:10001 infra/k8s/_worker_core.py      /app/_worker_core.py
COPY --chown=10001:10001 infra/k8s/_worker_resume.py    /app/_worker_resume.py
COPY --chown=10001:10001 infra/k8s/dispatch_logger.py   /app/dispatch_logger.py
COPY --chown=10001:10001 infra/k8s/jsonl_cost.py        /app/jsonl_cost.py
COPY --chown=10001:10001 infra/k8s/cli_adapters         /app/cli_adapters
RUN chmod -R 0555 /app/cli_worker_server.py /app/_worker_core.py \
        /app/_worker_resume.py /app/dispatch_logger.py /app/jsonl_cost.py \
    && find /app/cli_adapters -name '__pycache__' -type d -prune -exec rm -rf {} + 2>/dev/null || true

WORKDIR /app
USER 10001:10001

# tini reaps zombies (o worker faz shell-out via git/CLI subprocess).
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "/app/cli_worker_server.py"]
