# Critical: nothing secret leaves the build context.
**/.env
**/.env.*
!**/.env.example
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.key
**/*.pem
**/*.crt
**/*.p12
**/*credentials*
**/*secret*
**/*token*
# Exceções: arquivos do código com "secret"/"credential" no nome são CÓDIGO
# de segurança (módulo secrets_scanner, helpers de credentials), não
# segredos reais. As regras genéricas acima existem pra barrar dump de
# .env / .secrets / *credentials.json / etc — não código-fonte.
!deile/security/secrets_scanner.py
!deile/security/secrets_scanner_*.py
!deile/**/credentials_*.py
!deile/**/_secrets.py
!deile/tests/**/test_*secret*.py
!deile/tests/**/test_*credential*.py
!deile/tests/**/test_*token*.py

# Local state / caches / IDE
**/.git
**/.gitignore
**/.gitattributes
**/.venv
**/.venv_old
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
**/.coverage
**/htmlcov
**/.DS_Store
**/.vscode
**/.idea
**/.openclaude*
**/.claude
**/.worktrees
**/.ignore

# Runtime data + logs that may contain user content
data/
logs/
**/cache/
deile_tasks.db
deile.egg-info/
deilebot.egg-info/

# Test/dev/private artefacts
test-your-might/
deile/tests/might/
PATCHES/
PLANS/
RUNS/
docs/

# Stuff that's already in the deilebot subdir
deilebot/.git
deilebot/.venv
deilebot/__pycache__
deilebot/data
deilebot/logs
deilebot/.openclaude*
deilebot/.claude
deilebot/.worktrees
deilebot/PATCHES
deilebot/PLANS
deilebot/RUNS
deilebot/_testing.py
deilebot/conftest.py

# IDE / OS metadata
**/Thumbs.db
**/desktop.ini

# The infra/ subtree is excluded except for the files COPY'd explicitly
# by the Dockerfile. Excluding all of infra/ would break those COPYs —
# cada arquivo importado em `COPY infra/k8s/<x>` precisa de exceção `!`
# aqui ou o build falha com "not found".
infra/
!infra/k8s/wrapper.py
!infra/k8s/claude_worker_server.py
!infra/k8s/worker_server.py
!infra/k8s/_worker_resume.py
!infra/k8s/pipeline_status_server.py
!infra/k8s/dispatch_logger.py
!infra/k8s/jsonl_cost.py
