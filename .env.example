# --- LLM provider API keys (at least one is required at startup) -----------
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# --- deile → deile-bot integration -----------------------------------------
# Required for the messaging.discord_* tools to register & work.
# The deile-bot daemon (separate repo: elimarcavalli/deile-bot) exposes a
# control-plane HTTP server on 127.0.0.1; DEILE talks to it via a Bearer
# token. Both halves must share the same token.
#
#   DEILE_BOT_ENDPOINT     URL the daemon listens on (default 127.0.0.1:8765)
#   DEILE_BOT_AUTH_TOKEN   Bearer token; clients refuse to start with empty
DEILE_BOT_ENDPOINT=
DEILE_BOT_AUTH_TOKEN=
# Optional informational hint used by some tools when guild context is missing.
# DEILE_BOT_DEFAULT_GUILD_ID=
