# --- LLM provider API keys (at least one is required at startup) -----------
GOOGLE_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# --- deile → deilebot integration -----------------------------------------
# Required for the messaging.discord_* tools to register & work.
# The deilebot daemon (separate repo: elimarcavalli/deilebot) exposes a
# control-plane HTTP server on 127.0.0.1; DEILE talks to it via a Bearer
# token. Both halves must share the same token.
#
#   DEILE_BOT_ENDPOINT     URL the daemon listens on (default 127.0.0.1:8765)
#   DEILE_BOT_AUTH_TOKEN   Bearer token; clients refuse to start with empty
DEILE_BOT_ENDPOINT=
DEILE_BOT_AUTH_TOKEN=
# Optional informational hint used by some tools when guild context is missing.
# DEILE_BOT_DEFAULT_GUILD_ID=

# --- Trusted-operator opt-in (CLI / oneshot) -------------------------------
# When set to "1", waives the interactive ApprovalSystem prompt for HIGH-risk
# messaging tools (discord_send_dm, discord_mention_role) for THIS process.
# The waiver is still audited (severity WARNING + APPROVAL_GRANTED with
# details.approval=auto:trusted_operator) so the decision stays traceable.
# Keep OFF in production; turn on per-shell for batch / oneshot workflows.
# DEILE_BOT_APPROVAL_AUTO=1

# --- Vision tool model override --------------------------------------------
# Default: gemini-2.5-flash-lite ($0.10/$0.40 per 1M tokens).
# Override only if you want a more capable (more expensive) vision model.
# DEILE_VISION_MODEL=gemini-3-flash-preview

# --- Loop guard tuning (rarely needed) -------------------------------------
# Defaults: max 50 calls per turn; abort on 3 identical-in-a-row;
# 3 in any window of 5; 6 consecutive empty/error returns.
# DEILE_LOOP_GUARD_MAX_CALLS=50
# DEILE_LOOP_GUARD_REPEAT_THRESHOLD=3
# DEILE_LOOP_GUARD_WINDOW_SIZE=5
# DEILE_LOOP_GUARD_WINDOW_THRESHOLD=3
# DEILE_LOOP_GUARD_NO_PROGRESS=6
# Diagnostic kill switch (NEVER set in production):
# DEILE_LOOP_GUARD_DISABLE=1
