# ============================================================================
# DEILE — .env.example
# Copie para .env e preencha os valores. NUNCA commitar o .env real.
# Versão: fase 3 (#309)
#
# Nota: variáveis marcadas com [DEPRECATED] ainda funcionam mas devem ser
# migradas para ~/.deile/settings.json via `/settings set <chave> <valor>`.
# Exemplo: /settings set model.preferred anthropic:claude-sonnet-4-6
# ============================================================================

# ----------------------------------------------------------------------------
# 1. LLM PROVIDERS  (pelo menos UMA chave é obrigatória na inicialização)
# ----------------------------------------------------------------------------

# Anthropic — recomendado para uso com Claude Code subscription (PRO/MAX).
# Formato: sk-ant-... (começa com "sk-ant-")
ANTHROPIC_API_KEY=

# OpenAI — alternativo ao Anthropic.
# Formato: sk-... (começa com "sk-")
OPENAI_API_KEY=

# DeepSeek — alternativo, custo menor. Recomendado como modelo de fallback.
# Obtenha em: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Google Gemini — alternativo, necessário para ferramentas de visão (imagem).
# Obtenha em: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenRouter — gateway OpenAI-compatible: UMA chave → todos os modelos
# (DeepSeek, Qwen, Gemini, Claude, GPT, Llama…), cobrança única pay-per-token.
# base_url https://openrouter.ai/api/v1. Modelos via slug "openrouter:vendor/model"
# (ex: openrouter:deepseek/deepseek-chat, openrouter:anthropic/claude-sonnet-4.6).
# PRIVACIDADE: o prompt trafega por um hop adicional (OpenRouter) antes do
# provedor terceiro — ver DECISOES.md #50. Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo preferido global — formato "provider:modelo" (ex: anthropic:claude-sonnet-4-6).
# Pode ser sobrescrito por stage via DEILE_PIPELINE_MODEL_<STAGE>.
# [DEPRECATED → settings.json: model.preferred]
# Exemplo: /settings set model.preferred anthropic:claude-sonnet-4-6
# DEILE_PREFERRED_MODEL=anthropic:claude-sonnet-4-6

# Modelo usado pela ferramenta de visão (análise de imagens).
# Default: gemini-2.5-flash-lite (custo ~$0.10/$0.40 por 1M tokens).
# [DEPRECATED → settings.json: model.vision_model]
# DEILE_VISION_MODEL=gemini-2.5-flash-lite

# ----------------------------------------------------------------------------
# 2. FORGES  (GitHub OU GitLab — pode configurar ambos para multi-forge)
# ----------------------------------------------------------------------------

# GitHub Personal Access Token — scopes necessários: repo, workflow.
# Obtenha em: github.com/settings/tokens
GITHUB_TOKEN=

# GitLab Personal Access Token — scopes necessários: api, read_repository, write_repository.
# Obtenha em: gitlab.com/-/user_settings/personal_access_tokens
# Também aceito como GL_TOKEN (alias documentado pelo glab CLI).
GITLAB_TOKEN=
# GL_TOKEN=    # alias — use GITLAB_TOKEN ou GL_TOKEN, não os dois

# Tipo de forge padrão quando ambíguo. Valores: github | gitlab | auto.
# "auto" detecta por host/path. Para GitLab self-hosted ou GHE, definir explicitamente.
# [DEPRECATED → settings.json: forge.kind]
# DEILE_FORGE_KIND=auto

# Repo do pipeline — formato "owner/repo" (GH) ou "group/(subgroup/)*project" (GL).
# Usado pelo monitor autônomo para saber qual repositório monitorar.
# [DEPRECATED → settings.json: forge.repo  OU  pipeline.repo]
# DEILE_FORGE_REPO=elimarcavalli/deile
# DEILE_PIPELINE_REPO=elimarcavalli/deile    # alias legado — preferir DEILE_FORGE_REPO

# GitHub host — default: github.com.
# Para GitHub Enterprise Server: ghe.empresa.com (aceita CSV para múltiplos hosts).
# [DEPRECATED → settings.json: forge.github_host]
# DEILE_GITHUB_HOST=github.com

# GitLab host — default: gitlab.com.
# Para GitLab self-hosted: gitlab.empresa.com
# [DEPRECATED → settings.json: forge.gitlab_host]
# DEILE_GITLAB_HOST=gitlab.com

# Login do bot no forge — login GitHub/GitLab do usuário que representa o bot.
# Usado para evitar que o pipeline processe suas próprias ações como eventos novos.
# [DEPRECATED → settings.json: forge.bot_login]
# DEILE_FORGE_BOT_LOGIN=

# Prefixo da API GitHub — default: /api/v3 (GHE) ou vazio (github.com).
# [DEPRECATED → settings.json: forge.github_api_prefix]
# DEILE_GITHUB_API_PREFIX=

# Versão da API GitLab — default: v4.
# [DEPRECATED → settings.json: forge.gitlab_api_version]
# DEILE_GITLAB_API_VERSION=v4

# Ativa probe HTTP na inicialização do forge para verificar conectividade (1 = ativo).
# Útil para diagnosticar problemas de rede. Default: desativado.
# [DEPRECATED → settings.json: forge.probe_enabled]
# DEILE_FORGE_PROBE=0

# ----------------------------------------------------------------------------
# 3. DISCORD BOT  (opcional — habilita o deilebot; repo: elimarcavalli/deilebot)
# ----------------------------------------------------------------------------
#
# Perfil de deploy K8s — controla quais pods sobem com `k8s up` (issue #531).
# Valores válidos: pipeline-only | claude-only | full
#   pipeline-only  Minimal: deile-pipeline + deile-worker. Sem bot Discord.
#   claude-only    Pipeline + deile-worker + claude-worker. Sem bot Discord.
#   full           Todos os pods + deilebot. Exige DEILE_BOT_DISCORD_TOKEN.
# Default implícito: full — mas se DEILE_BOT_DISCORD_TOKEN estiver ausente e
# nenhum --profile / DEILE_K8S_DEPLOY_PROFILE for definido, k8s up faz
# fallback automático para claude-only (warn + exit 0, sem erro).
# Para forçar o erro ao usar full sem token, passe --profile full explicitamente.
# DEILE_K8S_DEPLOY_PROFILE=

# Token do bot Discord — crie o app em: discord.com/developers/applications
# Formato: <id>.<timestamp>.<hmac> (três partes separadas por ponto)
# Necessário somente para o perfil 'full' (sobe o pod deilebot + deile-shell).
DEILE_BOT_DISCORD_TOKEN=

# URL do daemon deilebot — endpoint que o DEILE usa para enviar comandos ao bot.
# Local: http://127.0.0.1:8765   |   K8s: http://deilebot:8765
# Required for the messaging.discord_* tools to register & work.
# The deilebot daemon (separate repo: elimarcavalli/deilebot) exposes a
# control-plane HTTP server on 127.0.0.1; DEILE talks to it via a Bearer
# token. Both halves must share the same token.
DEILE_BOT_ENDPOINT=

# Bearer token compartilhado entre o DEILE e o deilebot (controle seguro da API).
# Ambos os lados devem usar o mesmo token. Gerado automaticamente em K8s via deploy.py.
DEILE_BOT_AUTH_TOKEN=

# Guild ID padrão do Discord — dica opcional usada por algumas ferramentas
# quando o contexto de guild está ausente. Valor: ID numérico do servidor Discord.
# DEILE_BOT_DEFAULT_GUILD_ID=

# Timeout das requisições HTTP para o deilebot (segundos). Default: 10.0
# DEILE_BOT_TIMEOUT_S=10.0

# Tentativas de retry nas chamadas ao deilebot. Default: 3
# DEILE_BOT_RETRY_ATTEMPTS=3

# Desativa toda a integração com o bot mesmo que endpoint e token estejam configurados.
# Útil para testes isolados onde messaging tools nunca devem registrar/executar. Default: false
# DEILE_BOT_DISABLED=false

# Opt-in de aprovação automática para ferramentas de mensagem de alto risco
# (discord_send_dm, discord_mention_role). A aprovação ainda é auditada com
# severity=WARNING. NUNCA ativar em produção.
# [DEPRECATED → settings.json: approval.auto]
# DEILE_BOT_APPROVAL_AUTO=0

# ----------------------------------------------------------------------------
# 4. KUBERNETES — EXCLUSIVO PARA A STACK K8s  (deploy.py + Pods)
# ----------------------------------------------------------------------------

# Namespace Kubernetes usado pelo deploy.py. Default: deile.
# Override também disponível via flag --namespace no deploy.py.
DEILE_K8S_NAMESPACE=deile

# Arquivo de settings JSON montado no cluster como ConfigMap/volume.
# K8s-exclusivo: normalmente /etc/deile/settings.json (setado nos manifests).
# Não alterar localmente — uso interno do wrapper.py.
# DEILE_SETTINGS_FILE=/etc/deile/settings.json

# ---- deile-worker (Service :8766) ------------------------------------------

# Bearer token do deile-worker — gerado automaticamente pelo "k8s up" e
# armazenado no Secret "worker-bearer". Lido via arquivo /run/secrets/worker/token.
# Em ambiente local fora do cluster: setar manualmente para autenticar.
# DEILE_WORKER_BEARER_TOKEN=

# Token de autenticação do worker (lido diretamente do env, alternativa ao arquivo).
# Normalmente propagado pelo wrapper.py via /run/secrets/worker/token.
# DEILE_WORKER_AUTH_TOKEN=

# Caminho do arquivo com o bearer token do worker (alternativa à env var direta).
# Default: /run/secrets/worker/token (dentro do Pod).
# DEILE_WORKER_AUTH_TOKEN_FILE=

# Endpoint do deile-worker — URL base para o pipeline despachar tarefas.
# K8s: http://deile-worker:8766   |   local: http://localhost:8766
DEILE_WORKER_ENDPOINT=http://deile-worker:8766

# Host e porta onde o deile-worker escuta. Default: 0.0.0.0:8766.
# DEILE_WORKER_HOST=0.0.0.0
# DEILE_WORKER_PORT=8766

# Diretório raiz de trabalho do deile-worker (onde worktrees são criados).
# Default: /home/deile/work (dentro do Pod).
# DEILE_WORKER_ROOT=/home/deile/work

# Timeout máximo de uma task no deile-worker (segundos). Default: 7200 (2h).
# PRs grandes precisam de tempo (clone + análise + suite full ~5min +
# commits + push). Alinhado com DEILE_CLAUDE_WORKER_TASK_TIMEOUT_S.
DEILE_WORKER_TASK_TIMEOUT_S=7200

# Intervalo de edição no deile-worker — frequência de flush de progresso (segundos). Default: 3.
# DEILE_WORKER_EDIT_INTERVAL_S=3

# Tamanho máximo do brief enviado ao worker (caracteres). Default: 4000.
# DEILE_WORKER_MAX_BRIEF_CHARS=4000

# Tamanho máximo do histórico enviado ao worker (caracteres). Default: 8000.
# DEILE_WORKER_MAX_HISTORY_CHARS=8000

# Número máximo de tasks mantidas em memória no worker. Default: 500.
# DEILE_WORKER_MAX_INMEM_TASKS=500

# Nível de log do deile-worker. Valores: DEBUG | INFO | WARN | ERROR. Default: INFO.
# DEILE_WORKER_LOG_LEVEL=INFO

# ---- claude-worker (Service :8767) -----------------------------------------
# Pod paralelo que executa "claude -p" em worktrees isolados sob PVC próprio.
# Configurar apenas ao usar dispatch=claude-worker nos stages do pipeline.

# Endpoint do claude-worker — URL base para dispatch de tasks ao claude-worker.
# K8s: http://claude-worker:8767   |   local: http://localhost:8767
DEILE_CLAUDE_WORKER_ENDPOINT=http://claude-worker:8767

# Bearer token de autenticação do claude-worker.
# Gerado automaticamente pelo "k8s up" e armazenado no Secret "claude-worker-bearer".
# DEILE_CLAUDE_WORKER_AUTH_TOKEN=

# Caminho do arquivo com o bearer token do claude-worker.
# Default: /run/secrets/claude-worker/token (dentro do Pod).
# DEILE_CLAUDE_WORKER_AUTH_TOKEN_FILE=

# Host e porta onde o claude-worker escuta. Default: 0.0.0.0:8767.
# DEILE_CLAUDE_WORKER_HOST=0.0.0.0
# DEILE_CLAUDE_WORKER_PORT=8767

# Diretório raiz de trabalho do claude-worker (onde worktrees são criados).
# Default: /home/claude/work (dentro do Pod).
# DEILE_CLAUDE_WORKER_ROOT=/home/claude/work

# Timeout máximo de uma task no claude-worker (segundos). Default: 7200 (2h).
# PRs grandes (10k+ linhas) com suite full + review SOLID podem passar
# de 60min facilmente. Antes era 1800s — review do #344 morreu aos 30min
# com claude no meio do trabalho.
DEILE_CLAUDE_WORKER_TASK_TIMEOUT_S=7200

# Nível de log do claude-worker. Valores: DEBUG | INFO | WARN | ERROR. Default: INFO.
# DEILE_CLAUDE_WORKER_LOG_LEVEL=INFO

# Caminho do arquivo com a lista de repos permitidos para o claude-worker (regex).
# Montado via ConfigMap "claude-worker-allowed-repos". Default definido no wrapper.
# DEILE_CLAUDE_ALLOWED_REPOS_FILE=

# Whitelist de ferramentas disponíveis nos Pods (controle de segurança).
# Valores: all | messaging | (lista CSV de nomes de tool).
# K8s-exclusivo: setado nos manifests (all no deile-shell, messaging no deile-oneshot).
# DEILE_WRAPPER_TOOL_WHITELIST=all

# Persona inicial nos Pods K8s (deile-worker, deile-shell, deile-oneshot).
# Valor: nome da persona (ex: developer). Configurado nos manifests K8s.
# DEILE_DEFAULT_PERSONA=developer

# Override absoluto (tokens) do threshold resume→fresh; vazio ou 0 usa a fração abaixo.
# DEILE_CLAUDE_RESUME_TOKEN_BUDGET=

# Fração da janela do modelo usada como threshold de resume quando sem override absoluto. Default: 0.80.
# DEILE_CLAUDE_RESUME_CONTEXT_FRACTION=0.80

# Ledger append-only de custo por task. Default: ~/.claude/cost-ledger.jsonl.
# DEILE_CLAUDE_COST_LEDGER_PATH=~/.claude/cost-ledger.jsonl

# Grace period (s) para podar arquivos JSONL órfãos sem task associada. Default: 3600.
# DEILE_CLAUDE_JSONL_ORPHAN_GRACE_S=3600

# ---- Frota multi-CLI (opencode/codex/qwen/aider/goose — Services :8771-8775) -
# Pods plugáveis que rodam um CLI de codificação em worktree isolado, cada um
# dirigido por um adapter (infra/k8s/cli_adapters/<kind>.py — Decisão #51).
# Nascem com replicas:0 (custo zero ocioso) e escalam 0→1 sob demanda. As env
# vars abaixo são compartilhadas pelo servidor genérico (infra/k8s/cli_worker_server.py);
# cada Pod recebe o kind via DEILE_CLI_WORKER_KIND (setado no manifest gerado).
# Configurar apenas ao usar dispatch=<kind> em algum stage do pipeline.

# Host e porta onde o CLI worker escuta. Default do host: 0.0.0.0. Default da
# porta: o default_port do adapter (opencode 8771, codex 8772, qwen 8773,
# aider 8774, goose 8775).
# DEILE_CLI_WORKER_HOST=0.0.0.0
# DEILE_CLI_WORKER_PORT=

# Diretório raiz de trabalho do CLI worker. Default: /home/<kind>/work.
# DEILE_CLI_WORKER_ROOT=

# HOME gravável do CLI worker (passado ao env_overlay do adapter). Default: /home/<kind>.
# DEILE_CLI_WORKER_HOME=

# Timeout máximo de uma task no CLI worker (segundos). Default: 1800 (30min).
# DEILE_CLI_WORKER_TASK_TIMEOUT_S=1800

# Intervalo da task periódica de cleanup do PVC (segundos). Default: 3600 (1h).
# DEILE_CLI_WORKER_CLEANUP_INTERVAL_S=3600

# Dias de retenção dos workdirs antes da poda no cleanup. Default: 7.
# DEILE_CLI_WORKER_CLEANUP_RETENTION_DAYS=7

# Dias de retenção dos logs de progresso (.progress/*) antes da poda. Default: 30.
# DEILE_CLI_WORKER_PROGRESS_RETENTION_DAYS=30

# Grace period (s) antes de podar logs de progresso órfãos. Default: 3600.
# DEILE_CLI_WORKER_PROGRESS_GRACE_S=3600

# Ledger append-only de custo por task, colhido antes da poda dos logs (issue #445).
# Default: <DEILE_CLI_WORKER_ROOT>/.cost-ledger.jsonl.
# DEILE_CLI_WORKER_COST_LEDGER_PATH=

# Modo de auth OAuth opt-in por kind (default é auth via API key no env, que não
# expira). Setar para "oauth" só nos kinds oauth-capable (ex.: codex). Normalmente
# escrito no Deployment pelo "deploy.py k8s cli-worker-login <kind>", não à mão.
# DEILE_CODEX_AUTH=oauth

# Bearer token dos CLI workers. NÃO é env: é lido do Secret file
# /run/secrets/cli-worker/CLI_WORKER_BEARER_TOKEN (gerado pelo cli-worker-install).

# Teto de turns do goose (sem cap em USD nesses CLIs). Default: 40.
# DEILE_GOOSE_MAX_TURNS=40

# ----------------------------------------------------------------------------
# 5. PIPELINE AUTÔNOMO  (deile-pipeline Pod)
# ----------------------------------------------------------------------------

# Ativa o monitor de pipeline automaticamente no startup do CLI. Default: false.
# K8s: geralmente true no deile-pipeline Pod via DEILE_PIPELINE_AUTOSTART=1.
# [DEPRECATED → settings.json: pipeline.autostart]
# DEILE_PIPELINE_AUTOSTART=0

# Intervalo de polling do monitor (segundos). Default: 60.
# [DEPRECATED → settings.json: pipeline.poll_interval]
# DEILE_PIPELINE_POLL_INTERVAL=60

# Timeout máximo para execução de claude -p no pipeline (segundos). Default: 1800.
# [DEPRECATED → settings.json: pipeline.claude_timeout]
# DEILE_PIPELINE_CLAUDE_TIMEOUT=1800

# User ID Discord para notificações do pipeline (DM). Deixe vazio para silenciar.
# [DEPRECATED → settings.json: pipeline.notify_user_id]
# DEILE_PIPELINE_NOTIFY_USER_ID=

# Diretório base para os worktrees do pipeline (onde implementações são feitas).
# [DEPRECATED → settings.json: pipeline.base_path]
# DEILE_PIPELINE_BASE_PATH=

# ---- Sharding do monitor (execução paralela de múltiplos monitores) ---------

# Índice do shard atual (0-based). Default: 0 (shard único).
# Necessário apenas ao rodar múltiplas instâncias de deile-pipeline em paralelo.
# DEILE_PIPELINE_SHARD_INDEX=0

# Total de shards (instâncias do monitor). Default: 1.
# Com shard_count > 1, o lock ~batch:<sha8> é aplicado para evitar conflitos.
# DEILE_PIPELINE_SHARD_COUNT=1

# ---- Resume de trabalho parcial --------------------------------------------

# Ativa o resume automático de issues/PRs travados. Default: true.
# [DEPRECATED → settings.json: pipeline.resume_enabled]
# DEILE_PIPELINE_RESUME_ENABLED=1

# Intervalo entre tentativas de resume (segundos). Default: 0 (próximo tick livre).
# [DEPRECATED → settings.json: pipeline.resume_interval]
# DEILE_PIPELINE_RESUME_INTERVAL=0

# Número máximo de tentativas de resume por issue. Default: 10.
# [DEPRECATED → settings.json: pipeline.resume_max_attempts]
# DEILE_PIPELINE_RESUME_MAX_ATTEMPTS=10

# Orçamento de tempo total por resume (segundos). Default: 0 (sem limite).
# [DEPRECATED → settings.json: pipeline.resume_budget]
# DEILE_PIPELINE_RESUME_BUDGET=0

# ---- Refino / decomposição de intents --------------------------------------

# Liga o gate de refino/decomposição (crítica → loop de refino → decompose).
# Default: true. Independente do dispatch_mode (issue #85): o dispatch_resolver
# decide QUEM executa cada stage; este flag decide SE o pipeline refina/decompõe.
# Ex.: =0 desliga o gate mesmo sob a frota all-claude (DISPATCH_MODE=claude).
# [DEPRECATED → settings.json: pipeline.refinement_gate]
# DEILE_PIPELINE_REFINEMENT_GATE=1

# ---- Dispatch routing (qual worker recebe cada stage) ----------------------

# Worker padrão global para todos os stages.
# Valores: deile-worker | claude-worker | opencode | codex | qwen | aider | goose.
# Os 5 últimos são CLI workers da frota multi-CLI (ver seção 4, Decisão #51).
# Resolvido por deile/orchestration/pipeline/dispatch_resolver.py.
# Override por stage via DEILE_PIPELINE_DISPATCH_<STAGE>.
# [DEPRECATED → settings.json: pipeline.dispatch_mode]
DEILE_PIPELINE_DISPATCH_MODE=deile-worker

# Worker por stage — sobrescreve o global. Mesmos valores do MODE acima
# (vazio = cai no global). STAGE ∈ classify | refine | implement | pr_review | follow_ups.
# Configurável também via painel TUI: tecla [d] → DispatchMatrixView.
# DEILE_PIPELINE_DISPATCH_CLASSIFY=
# DEILE_PIPELINE_DISPATCH_REFINE=
# DEILE_PIPELINE_DISPATCH_IMPLEMENT=
# DEILE_PIPELINE_DISPATCH_PR_REVIEW=
# DEILE_PIPELINE_DISPATCH_FOLLOW_UPS=

# ---- Modelo LLM por stage --------------------------------------------------
# Formato: "provider:modelo" (ex: anthropic:claude-sonnet-4-6, deepseek:deepseek-v4-pro).
# Para CLI workers da frota, use o slug que o adapter aceita (ex.: OpenRouter
# "openrouter:vendor/model"; goose exige o prefixo provider/ no id — ver adapter).
# Resolvido por deile/orchestration/pipeline/model_resolver.py (resolve_stage_cli_model).
# Stages sem override usam DEILE_PREFERRED_MODEL como fallback global.
# Configurável também via painel TUI: tecla [d] → coluna Model na DispatchMatrixView.
# DEILE_PIPELINE_MODEL_CLASSIFY=
# DEILE_PIPELINE_MODEL_REFINE=
# DEILE_PIPELINE_MODEL_IMPLEMENT=
# DEILE_PIPELINE_MODEL_PR_REVIEW=
# DEILE_PIPELINE_MODEL_FOLLOW_UPS=

# ---- Reasoning effort (esforço de raciocínio) por stage --------------------
# Níveis: anthropic/claude-worker → low|medium|high|xhigh|max|ultracode|auto.
#         openai   → none|minimal|low|medium|high|xhigh|auto.
#         gemini   → off|minimal|low|medium|high|auto.
#         deepseek → off|high|max|auto.
# Stages sem override usam DEILE_REASONING_EFFORT como fallback global.
# Configurável também via painel TUI ([d] → coluna Reasoning) e no DEILE CLI
# (comando /reasoning <nível> ou flag --reasoning LEVEL). Ver deile/core/models/reasoning.py.
# DEILE_REASONING_EFFORT=high
# DEILE_PIPELINE_REASONING_CLASSIFY=
# DEILE_PIPELINE_REASONING_REFINE=
# DEILE_PIPELINE_REASONING_IMPLEMENT=
# DEILE_PIPELINE_REASONING_PR_REVIEW=
# DEILE_PIPELINE_REASONING_FOLLOW_UPS=

# ----------------------------------------------------------------------------
# 6. SUBAGENTES PARALELOS  (dispatch_parallel_subagents)
# ----------------------------------------------------------------------------

# Runner dos subagentes. Valores: local (in-process) | worker (via HTTP ao deile-worker).
# Default: local.
# [DEPRECATED → settings.json: subagent.runner]
# DEILE_SUBAGENT_RUNNER=local

# Máximo de subagentes rodando em paralelo por chamada. Default: 3.
# [DEPRECATED → settings.json: subagent.max_parallel]
# DEILE_SUBAGENT_MAX_PARALLEL=3

# Intervalo de polling do WorkerSubAgentRunner (segundos). Default: 0.8.
# [DEPRECATED → settings.json: subagent.poll_interval_s]
# DEILE_SUBAGENT_POLL_INTERVAL_S=0.8

# Orçamento de tempo total por batch de subagentes (segundos). Default: 600.0.
# [DEPRECATED → settings.json: subagent.budget_s]
# DEILE_SUBAGENT_BUDGET_S=600.0

# Tamanho máximo do buffer de captura de saída por subagente (bytes). Default: 262144 (256 KiB).
# [DEPRECATED → settings.json: subagent.capture_buffer_max_bytes]
# DEILE_SUBAGENT_CAPTURE_BUFFER_MAX_BYTES=262144

# ----------------------------------------------------------------------------
# 7. LOOP GUARD  (proteção contra loops infinitos de tool calls)
# ----------------------------------------------------------------------------

# Desativa completamente o loop guard. NUNCA usar em produção. Default: false.
# [DEPRECATED → settings.json: loop_guard.disabled]
# DEILE_LOOP_GUARD_DISABLE=0

# Número máximo de tool calls por turno. Default: 50.
# [DEPRECATED → settings.json: loop_guard.max_calls]
# DEILE_LOOP_GUARD_MAX_CALLS=50

# Interrompe se a mesma call aparecer N vezes seguidas. Default: 3.
# [DEPRECATED → settings.json: loop_guard.repeat_threshold]
# DEILE_LOOP_GUARD_REPEAT_THRESHOLD=3

# Tamanho da janela deslizante para detectar repetição. Default: 5.
# [DEPRECATED → settings.json: loop_guard.window_size]
# DEILE_LOOP_GUARD_WINDOW_SIZE=5

# Número de repetições na janela que dispara abort. Default: 3.
# [DEPRECATED → settings.json: loop_guard.window_threshold]
# DEILE_LOOP_GUARD_WINDOW_THRESHOLD=3

# Abort após N retornos consecutivos vazios/erro sem progresso. Default: 6.
# [DEPRECATED → settings.json: loop_guard.no_progress]
# DEILE_LOOP_GUARD_NO_PROGRESS=6

# Máximo de iterações do loop de tool calls (sobrescreve max_calls em agent.py).
# [DEPRECATED → settings.json: agent.max_tool_iterations]
# DEILE_MAX_TOOL_ITERATIONS=100

# ----------------------------------------------------------------------------
# 8. CRON  (tarefas agendadas — CronStore SQLite + CronRunner)
# ----------------------------------------------------------------------------

# Caminho do banco SQLite do cron. Default: ~/.deile/cron.sqlite.
# [DEPRECATED → settings.json: cron.db_path]
# DEILE_CRON_DB_PATH=

# Intervalo de polling do CronRunner (segundos). Default: 30.
# [DEPRECATED → settings.json: cron.poll_interval]
# DEILE_CRON_POLL_INTERVAL=30

# Ativa o cron automaticamente na inicialização do Pod (K8s-exclusivo).
# Setado no manifest do deilebot (DEILE_CRON_AUTOSTART=1).
# DEILE_CRON_AUTOSTART=0

# ----------------------------------------------------------------------------
# 9. OBSERVABILIDADE  (OpenTelemetry — opcional)
# ----------------------------------------------------------------------------

# OTLP endpoint para exportar traces e métricas. Vazio = no-op (sem export).
# Exemplo: http://otel-collector:4317 (gRPC) ou http://otel-collector:4318 (HTTP)
DEILE_OTLP_ENDPOINT=

# Headers adicionais para o OTLP exporter. Formato: "key=value,key2=value2".
# Útil para autenticação em backends SaaS (ex: Honeycomb, Grafana Cloud).
# DEILE_OTLP_HEADERS=

# Desativa TLS na conexão OTLP (true = inseguro, aceitar HTTP). Default: true.
# DEILE_OTLP_INSECURE=true

# Nome do serviço no OTLP. Default: "deile".
# DEILE_OTLP_SERVICE_NAME=deile

# Taxa de amostragem de traces (0.0 a 1.0). Default: 1.0 (100%).
# DEILE_OTLP_SAMPLE_RATIO=1.0

# Desativa completamente a observabilidade mesmo com endpoint configurado.
# DEILE_OBSERVABILITY_DISABLED=false

# ----------------------------------------------------------------------------
# 10. RUNTIME STATE  (state files + status server)
# ----------------------------------------------------------------------------

# Diretório onde os arquivos de estado de instâncias DEILE são publicados.
# Default: ~/.deile/run/ (criado automaticamente).
# O painel TUI lê deste diretório para exibir instâncias ativas.
# DEILE_RUNTIME_DIR=

# ----------------------------------------------------------------------------
# 11. DEILE INTERNO / DEBUG  (raramente alterar)
# ----------------------------------------------------------------------------

# Ativa modo debug global (logging verboso + diagnósticos extras). Default: false.
# [DEPRECATED → settings.json: debug.enabled]
# DEILE_DEBUG=0

# Usuário GitHub para exibição no painel TUI (fallback quando "gh api user" falha).
# Opcional — o painel detecta automaticamente via "gh api user" se omitido.
# GH_USER=
